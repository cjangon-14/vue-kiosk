# API Configuration
# 
# For local development:
# - Leave empty to use mock data from apiService.js
# - Or set to http://localhost:3000 if using real backend
#
# For Vercel deployment:
# - Leave empty to use /api serverless functions
# - Or set to your backend API URL

# API Base URL (optional)
# VITE_API_URL=

# Environment
# VITE_ENV=development
# VITE_ENV=production
